#!/usr/bin/env bash
set -euo pipefail

# ANSI color codes for consistent error formatting
BOLD=$'\e[1m'; RED=$'\e[31m'; RESET=$'\e[0m'
[[ -t 1 ]] || { BOLD=; RED=; RESET=; }
err() { printf '%s✗%s %s\n' "$RED" "$RESET" "$*" >&2; }
die() { err "$*"; exit 1; }

# --help / -h: print copy-pastable usage and exit BEFORE any Docker work, so help still works when
# Docker is down or the image isn't built yet. We resolve our own location so every command printed
# below is copy-pastable as-is — no matter where the repo was cloned or whether the alias is set up.
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  row() { printf '  %-18s %s%s%s\n' "$1" "$BOLD" "$2" "$RESET"; }
  printf '%sclaude-pod%s — run Claude Code in a Docker sandbox scoped to the current folder.\n' "$BOLD" "$RESET"
  printf '\n%sRun%s  (cd into your project first — the current folder is what gets mounted):\n' "$BOLD" "$RESET"
  row "Open a shell:"   "$HERE/claude-pod"
  row "Run Claude:"     "$HERE/claude-pod claude --dangerously-skip-permissions"
  row "Run via Happy:"  "$HERE/claude-pod happy --claude-arg --dangerously-skip-permissions"
  printf '\n%sManage%s  (works from any folder):\n' "$BOLD" "$RESET"
  row "Install/update:" "$HERE/install.sh"
  row "Pin a version:"  "CLAUDE_CODE_VERSION=2.0.0 $HERE/install.sh"
  row "Uninstall:"      "$HERE/uninstall.sh"
  printf '\n%sOptions%s  (prefix any run command):\n' "$BOLD" "$RESET"
  row "Publish ports:"  "PORTS=\"3000 5173\" $HERE/claude-pod"
  row "Isolate/limit:"  "NET=none MEMORY=4g CPUS=2 PIDS=512 $HERE/claude-pod"
  row "Reach host services:" "HOST_SERVICES=1 $HERE/claude-pod"
  row "  ...specific ports:" "HOST_SERVICES=\"27017 8000\" $HERE/claude-pod (transparent localhost proxy, scoped to just those ports)"
  row "Whitelist MCP servers:" "MCP_SERVERS=codegraph $HERE/claude-pod (default; MCP_SERVERS=none to disable)"
  row "Forward MCP secrets:" "MCP_SERVER_ENV=AGENTMEMORY_SECRET $HERE/claude-pod"
  row "Custom config dir:" "CLAUDE_CONFIG_DIR=~/.claude-tessero $HERE/claude-pod (default ~/.claude; same var Claude Code itself uses)"
  row "Custom state dir:" "CLAUDE_POD_HOME=~/.claude-pod-tessero $HERE/claude-pod (default ~/.claude-pod; pair with CLAUDE_CONFIG_DIR for parallel accounts)"
  row "Custom Happy state dir:" "HAPPY_HOME_DIR=~/.happy-pod $HERE/claude-pod (default ~/.happy, shared with any host-side happy; same var Happy itself uses)"
  printf '\n'
  row "Shortcut alias:" "alias claude-pod=$HERE/claude-pod"
  row "Full README:"    "https://github.com/bmiller59/claude-pod"
  exit 0
fi

# Preflight checks, in causal order. Without these the failures surface as cryptic Docker errors:
#   - daemon down -> the image check below would falsely blame a missing image.
#   - missing image -> Docker would try to pull 'claude-pod' from Docker Hub and fail.
# We probe existence with `image ls -q`, not `image inspect`: it resolves the name the same way
# `docker run` does, so the check can't disagree with whether the run will actually work. (Some
# Docker Desktop builds have a broken `image inspect <name>` that false-negatives on a present
# image, which would otherwise wrongly send you to re-run install.sh.)
command -v docker >/dev/null || die "Docker is required but not on PATH."
docker info >/dev/null 2>&1 || die "Docker daemon is not running."
if [ -z "$(docker image ls -q claude-pod 2>/dev/null)" ]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  err "Image 'claude-pod' not found."
  die "Please run '${BOLD}${SCRIPT_DIR}/install.sh${RESET}' first to build the local container."
fi

# Host-side state dir: persists Claude's auth + history across container restarts.
# Overridable via CLAUDE_POD_HOME (default $HOME/.claude-pod) so you can run multiple pods in
# parallel -- e.g. logged into different Claude accounts -- without them sharing auth/session
# state. Pair it with CLAUDE_CONFIG_DIR (see below) using a matching suffix, e.g.
# CLAUDE_CONFIG_DIR=~/.claude-tessero CLAUDE_POD_HOME=~/.claude-pod-tessero.
POD_HOME="${CLAUDE_POD_HOME:-$HOME/.claude-pod}"
mkdir -p "$POD_HOME"

# Claude reads its main config from $HOME/.claude.json (a file at HOME, sibling to the .claude/
# directory). We bind-mount this file separately so login state survives. Two quirks:
#   - Docker creates a directory at the target if the source path is missing, so the file must
#     pre-exist on the host before `docker run`.
#   - Claude treats an empty file as a JSON parse error, not as "no config", so we seed it with {}.
[ -s "$POD_HOME/.claude.json" ] || printf '{}' > "$POD_HOME/.claude.json"

# Restrict to owner-only. The directory holds the Anthropic auth token and session transcripts
# (which can contain code, file contents, and command output Claude saw); on multi-user hosts the
# default 755/644 modes would let other local users read both. Matches the convention used for
# ~/.ssh, ~/.aws, ~/.gnupg.
chmod 700 "$POD_HOME"
chmod 600 "$POD_HOME/.claude.json"

# Happy Coder CLI (https://happy.engineering) is baked into the image as an optional way to run
# Claude -- `claude-pod happy --claude-arg --dangerously-skip-permissions` instead of `claude-pod
# claude --dangerously-skip-permissions`. It keeps its own state (auth/session data for the mobile
# pairing) under HAPPY_HOME_DIR -- that's Happy's own env var, default $HOME/.happy, not one we
# invented, so it behaves the same whether `happy` is run directly on the host or via claude-pod.
# Unlike CLAUDE_POD_HOME, this default is NOT pod-exclusive: if you also run `happy` on the host,
# the pod shares that same state dir by default. Point HAPPY_HOME_DIR at a separate directory
# (e.g. ~/.happy-pod) if you want the pod's happy state kept apart from the host's -- and note
# uninstall.sh deliberately does NOT remove this dir, since by default it may be host state, not
# pod-exclusive state the way ~/.claude-pod is.
HAPPY_HOME="${HAPPY_HOME_DIR:-$HOME/.happy}"
mkdir -p "$HAPPY_HOME"
chmod 700 "$HAPPY_HOME"

# Mounts & Users:
#   --user -> dynamic                            Runs container exactly as the host user to prevent permission issues.
#   HOME=/home/claude-pod                        Because user is dynamic, we use a dedicated writable home dir.
#   $PWD -> $PWD                                 project files; same path on both sides keeps file
#                                                references (logs, errors, tool output) consistent
#                                                between host and container.
#   $POD_HOME -> /home/claude-pod/.claude        credentials, sessions, history (the .claude dir).
#                                                default ~/.claude-pod; override with CLAUDE_POD_HOME.
#   $POD_HOME/.claude.json -> ditto              account binding + project trust state (sibling file).
#   $HAPPY_HOME -> /home/claude-pod/.happy       Happy Coder CLI's own state; default ~/.happy;
#                                                override with HAPPY_HOME_DIR.
# TTY Detection:
#   If we pipe data into the script (e.g. `cat file | claude-pod`), input is not a terminal.
#   Passing `-t` to Docker in this case would cause a crash.
#   [ -t 0 ] checks if STDIN is a terminal. If yes, keep it interactive (-i).
#   [ -t 1 ] checks if STDOUT is a terminal. If yes, allocate a pseudo-TTY (-t).
DOCKER_FLAGS=("--rm")
[ -t 0 ] && DOCKER_FLAGS+=("-i")
[ -t 1 ] && DOCKER_FLAGS+=("-t")

# Optional Port Mapping:
#   Allows users to map dev servers by passing PORTS="3000 8080:80".
#   We force binding to 127.0.0.1 to prevent exposing dev servers to public networks.
#   Each entry must be either "PORT" or "HOST:CONTAINER", with both parts in the 1-65535 range.
#   We validate up front so a typo surfaces as a clear error here rather than a cryptic Docker failure.
if [ -n "${PORTS:-}" ]; then
  for port in $PORTS; do
    if [[ ! "$port" =~ ^[0-9]+(:[0-9]+)?$ ]]; then
      die "PORTS entry '$port' is invalid; expected 'PORT' or 'HOST:CONTAINER' (digits only)."
    fi
    # Range-check each numeric component. 10# forces base-10 so "08"/"09" don't parse as octal.
    IFS=':' read -ra _port_parts <<< "$port"
    for _n in "${_port_parts[@]}"; do
      if (( 10#$_n < 1 || 10#$_n > 65535 )); then
        die "PORTS entry '$port' has '$_n' outside the 1-65535 range."
      fi
    done
    if [[ "$port" == *":"* ]]; then
      DOCKER_FLAGS+=("-p" "127.0.0.1:${port}")
    else
      DOCKER_FLAGS+=("-p" "127.0.0.1:${port}:${port}")
    fi
  done
fi

# Optional Network Isolation:
#   By default the container has unrestricted outbound networking — Claude needs api.anthropic.com,
#   and your builds need the npm/pip/etc. registries. Set NET=none to cut ALL networking for the run.
#   Use this to inspect or build code from an untrusted source offline: with no network, a malicious
#   payload can't exfiltrate the project or phone home. Note that Claude itself can't reach Anthropic
#   in this mode, so it's for sandboxed shell/build work, not for a live Claude session.
#   NET=none and PORTS are mutually exclusive — you can't publish a port on a container with no network.
if [ "${NET:-}" = "none" ]; then
  [ -n "${PORTS:-}" ] && die "NET=none and PORTS are mutually exclusive: a no-network container can't publish ports."
  DOCKER_FLAGS+=("--network=none")
fi

# Optional Host-Service Reachability:
#   Off by default. HOST_SERVICES=1 adds --add-host so the container can resolve
#   host.docker.internal, letting test code inside the pod reach a service bound to the host's
#   loopback interface. Point test config at host.docker.internal:<port> the same way you'd use
#   `extra_hosts` in a docker-compose file.
#   Platform caveat: on native Linux Docker, host.docker.internal resolves to the Docker bridge
#   gateway IP (e.g. 172.17.0.1), NOT to 127.0.0.1. A service bound only to loopback -- the default
#   for a stock Postgres or Redis install -- will NOT accept the connection even though the name
#   resolves; rebind the service to 0.0.0.0 (or the bridge-facing interface) to reach it. Docker
#   Desktop (macOS/Windows) routes host.docker.internal through its VM differently and may not
#   share this limitation -- not verified here.
#   Deliberately coarse: once resolvable, the container can reach ANY port on the host's loopback,
#   not just the one your tests use. Docker has no docker-run flag or compose key that restricts
#   *which* host ports host-gateway can reach.
#   Mutually exclusive with NET=none: a no-network container can't resolve or reach the host either.
#
#   HOST_SERVICES can also be a space-separated port list instead of "1", e.g. HOST_SERVICES="27017
#   8000". Beyond --add-host, this starts a per-port socat relay inside the container (see the
#   Dockerfile's entrypoint) listening on the container's OWN 127.0.0.1:<port> and forwarding to
#   host.docker.internal:<port>. That makes reaching the host service transparent: test config left
#   pointed at localhost:<port> works unchanged whether you're in the pod or not, no
#   host.docker.internal rewrite needed. Scoped to exactly the ports you name, unlike the "1" form.
if [ -n "${HOST_SERVICES:-}" ]; then
  [ "${NET:-}" = "none" ] && die "HOST_SERVICES and NET=none are mutually exclusive: a no-network container can't reach the host either."
  DOCKER_FLAGS+=("--add-host=host.docker.internal:host-gateway")
  if [ "$HOST_SERVICES" != "1" ]; then
    for _hs_port in $HOST_SERVICES; do
      if [[ ! "$_hs_port" =~ ^[0-9]+$ ]]; then
        die "HOST_SERVICES entry '$_hs_port' is invalid; expected the literal '1' or a space-separated list of ports (digits only)."
      fi
      if (( 10#$_hs_port < 1 || 10#$_hs_port > 65535 )); then
        die "HOST_SERVICES entry '$_hs_port' is outside the 1-65535 range."
      fi
    done
    DOCKER_FLAGS+=("-e" "HOST_FORWARD_PORTS=$HOST_SERVICES")
  fi
fi

# Resource Limits (host availability):
#   Dropping capabilities does NOT stop fork() or memory allocation, so a runaway or malicious
#   process inside the container can still fork-bomb or exhaust memory and drag the host down.
#   --pids-limit caps total processes/threads. The default is generous enough for normal builds;
#     raise it with PIDS= for very parallel builds, or lower it when running untrusted code.
#   MEMORY/CPUS are opt-in with no default on purpose: a fixed memory cap would OOM-kill legitimate
#     large builds, and the right ceiling depends on your host's RAM. Set e.g. MEMORY=4g CPUS=2
#     when running code you don't trust.
DOCKER_FLAGS+=("--pids-limit=${PIDS:-4096}")
[ -n "${MEMORY:-}" ] && DOCKER_FLAGS+=("--memory=$MEMORY")
[ -n "${CPUS:-}" ]   && DOCKER_FLAGS+=("--cpus=$CPUS")

# Optional Claude Config Access (skills, plugins, global instructions):
#   On by default. Bind-mounts a curated, read-only subset of the host's ~/.claude/ (plus
#   ~/.agents, which some skill-manager setups symlink ~/.claude/skills/* into) so Claude behaves
#   the same inside the pod as it does on the host: personal skills, installed plugins, global
#   CLAUDE.md, and settings.json/statusline.sh. Read-only (":ro") -- the container can see these
#   but never write back to them.
#   Deliberately NOT the whole ~/.claude/ directory: that also holds .credentials.json,
#   history.jsonl, and projects/ (session transcripts from every OTHER project you've used Claude
#   Code on), which would blow a hole in "other projects are unreachable" (see README's Security
#   and limits).
#   Source dir is overridable via CLAUDE_CONFIG_DIR (default $HOME/.claude), matching upstream
#   Claude Code's own env var of the same name/semantics -- if you already use it to switch
#   accounts on the host (e.g. CLAUDE_CONFIG_DIR=~/.claude-tessero), the same value works here.
#   ~/.agents is NOT part of this override: it's a skill-manager symlink target unrelated to which
#   Claude account/profile is active, so it always comes from $HOME regardless of CLAUDE_CONFIG_DIR.
#   Each path is mounted only if it exists on the host. This matters, not just tidiness: Docker's
#   bind mount auto-creates the *target* path when the *source* is missing, and since source and
#   target share the same relative path here, an unconditional mount would silently create an
#   empty file/directory inside the user's real config dir or ~/.agents the first time this ran
#   without one of these paths present -- mutating host state, which this tool otherwise never
#   does.
CLAUDE_SRC_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
[ -n "${CLAUDE_CONFIG_DIR:-}" ] && [ ! -d "$CLAUDE_CONFIG_DIR" ] && die "CLAUDE_CONFIG_DIR '$CLAUDE_CONFIG_DIR' does not exist or is not a directory."
CLAUDE_HOME_ITEMS=(skills plugins CLAUDE.md settings.json statusline.sh)
for _claude_home_item in "${CLAUDE_HOME_ITEMS[@]}"; do
  [ -e "$CLAUDE_SRC_DIR/$_claude_home_item" ] && DOCKER_FLAGS+=("-v" "$CLAUDE_SRC_DIR/$_claude_home_item:/home/claude-pod/.claude/$_claude_home_item:ro")
done
[ -e "$HOME/.agents" ] && DOCKER_FLAGS+=("-v" "$HOME/.agents:/home/claude-pod/.agents:ro")

# Optional MCP Server Whitelist:
#   Defaults to "codegraph" -- this fork's one personal default (see CLAUDE.md), since it's used
#   constantly here. Override with MCP_SERVERS="codegraph agentmemory" (replaces the default
#   entirely -- include "codegraph" yourself if you still want it alongside others), or disable
#   with MCP_SERVERS=none. The default only applies when the var is completely unset (`${VAR-x}`,
#   no colon) so MCP_SERVERS="" also means "nothing", same as MCP_SERVERS=none.
#   Copies just the named entries out of the host's real ~/.claude.json (top-level mcpServers
#   object -- a file this tool otherwise never touches) and replaces the mcpServers key in the
#   pod's own $POD_HOME/.claude.json with exactly that set. This is a rewrite of the pod's live
#   config file, not a bind mount: Claude Code writes to this file routinely (project trust,
#   session state), so it has to stay writable, and there's no way to bind-mount "just one key" of
#   a JSON file.
#   Reads from $CLAUDE_CONFIG_DIR/.claude.json when CLAUDE_CONFIG_DIR is set, matching upstream
#   Claude Code's own behavior of relocating .claude.json inside a custom config dir (confirmed by
#   inspecting an actual profile dir; not documented upstream). Falls back to $HOME/.claude.json
#   otherwise. This makes MCP whitelisting automatically per-profile, same as skills/plugins/etc.
#   Full replace, every run, including when the resolved list is empty: a server whitelisted on an
#   earlier run must NOT stay active on a later run that no longer asks for it -- the sync step
#   below always runs, not just when the list is non-empty, specifically to clear that case.
#   Requires jq on the host, but only enforced when the resolved list is non-empty (checked here,
#   not at the top) -- this is the one case where "Docker is the only requirement" gets a footnote.
#   If a host has never used this feature and has no jq, the sync step below silently no-ops
#   instead of erroring, since there's nothing to clear.
#   A server's underlying command must already exist in the image (e.g. `codegraph`, added to the
#   Dockerfile) or the MCP connection will simply fail to start inside the pod; this script doesn't
#   install anything.
#   Secrets referenced by a whitelisted server's env config (e.g. an API token) are NOT forwarded
#   automatically -- see MCP_SERVER_ENV below. Auto-detecting and forwarding them would expose a
#   credential to the sandbox by surprise.
MCP_SERVERS="${MCP_SERVERS-codegraph}"
[ "$MCP_SERVERS" = "none" ] && MCP_SERVERS=""

CLAUDE_JSON="$HOME/.claude.json"
[ -n "${CLAUDE_CONFIG_DIR:-}" ] && CLAUDE_JSON="$CLAUDE_CONFIG_DIR/.claude.json"

MCP_MERGED='{}'
if [ -n "${MCP_SERVERS:-}" ]; then
  command -v jq >/dev/null || die "MCP_SERVERS requires jq on the host (e.g. 'brew install jq' or 'apt-get install jq')."
  [ -f "$CLAUDE_JSON" ] || die "MCP_SERVERS is set but $CLAUDE_JSON doesn't exist -- no MCP servers are configured for this profile."

  for _mcp_name in $MCP_SERVERS; do
    _mcp_entry="$(jq -c --arg n "$_mcp_name" '.mcpServers[$n] // empty' "$CLAUDE_JSON")"
    [ -n "$_mcp_entry" ] || die "MCP_SERVERS entry '$_mcp_name' not found in $CLAUDE_JSON's mcpServers."
    MCP_MERGED="$(jq -cn --argjson obj "$MCP_MERGED" --arg n "$_mcp_name" --argjson e "$_mcp_entry" '$obj + {($n): $e}')"
  done
fi

# Always sync (not just when MCP_SERVERS is set) -- see comment above. Best-effort when jq isn't
# on PATH: a host that has never used MCP_SERVERS has nothing to clear, so silently skip rather
# than newly requiring jq on every run.
if command -v jq >/dev/null 2>&1; then
  # Rewrite-then-chmod: jq's output redirection creates a new inode at the default umask, which
  # would silently regress this file back to world-readable -- it carries account/session state.
  jq --argjson mcp "$MCP_MERGED" '.mcpServers = $mcp' "$POD_HOME/.claude.json" > "$POD_HOME/.claude.json.tmp" \
    && mv "$POD_HOME/.claude.json.tmp" "$POD_HOME/.claude.json"
  chmod 600 "$POD_HOME/.claude.json"
fi

# Optional MCP Server Env Passthrough:
#   Off by default. MCP_SERVER_ENV="AGENTMEMORY_SECRET" forwards exactly the named host env vars
#   into the container (bare `-e NAME`, same pass-through style as COLORTERM below) -- for MCP
#   servers whose config (see MCP_SERVERS above) references them, e.g. agentmemory's
#   AGENTMEMORY_URL/AGENTMEMORY_SECRET. You name exactly which vars cross into the sandbox; nothing
#   is inferred from a server's config, so a credential never ends up in the container by surprise.
if [ -n "${MCP_SERVER_ENV:-}" ]; then
  for _mcp_env_var in $MCP_SERVER_ENV; do
    DOCKER_FLAGS+=("-e" "$_mcp_env_var")
  done
fi

# Hardening:
#   --cap-drop=ALL                       Drop all Linux capabilities. An interactive dev shell
#                                        as an unprivileged user needs none; this closes off
#                                        capability-based escalation paths (CAP_NET_RAW, etc.)
#                                        and shrinks the surface for known container-escape CVEs.
#   --security-opt=no-new-privileges     Set NO_NEW_PRIVS on the process tree. Even if a setuid
#                                        binary in the image (passwd, su, mount, ...) ever has
#                                        a local-root vulnerability, it cannot elevate.
#
# COLORTERM is forwarded so Claude Code's TUI can emit full 24-bit color when the host terminal
# supports it. Bare `-e COLORTERM` (no value) passes the host's setting through — "truecolor" on
# iTerm2, VS Code, WezTerm, etc., or nothing when the host doesn't advertise it, so a non-truecolor
# terminal is never forced into colors it can't render. Without this, docker leaves the container at
# TERM=xterm with no COLORTERM and supports-color downshifts the whole UI to 16 colors.
exec docker run "${DOCKER_FLAGS[@]}" \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  --user "$(id -u):$(id -g)" \
  -e HOME=/home/claude-pod \
  -e COLORTERM \
  -v "$PWD:$PWD" \
  -w "$PWD" \
  -v "$POD_HOME:/home/claude-pod/.claude" \
  -v "$POD_HOME/.claude.json:/home/claude-pod/.claude.json" \
  -v "$HAPPY_HOME:/home/claude-pod/.happy" \
  claude-pod "$@"
